<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.SettingsControl">
    <ScrollViewer>
        <StackPanel Spacing="20">
            <!-- App Updates (1st) -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="APP UPDATES" FontWeight="Bold" Foreground="#F9E2AF" Margin="0,0,0,10"/>
                    <CheckBox Name="ChkAutoUpdate" Content="Check for updates on startup" Foreground="White"/>
                    <Button Name="BtnCheckUpdates" Classes="Primary Settings" Content="CHECK FOR UPDATES" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Backup Health Dashboard (2nd) -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="20">
                <StackPanel Spacing="15">
                    <TextBlock Text="BACKUP HEALTH DASHBOARD" FontWeight="Bold" Foreground="#A6E3A1" Margin="0,0,0,10"/>
                    <Button Name="BtnDiagnostics" Classes="Primary Settings" Content="RUN SYSTEM DIAGNOSTICS" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"/>
                    <TextBlock Name="TxtHealthStatus" Text="Status: Pending Scan..." Foreground="#A6ADC8" FontStyle="Italic" TextTrimming="CharacterEllipsis"/>
                </StackPanel>
            </Border>

            <!-- System Configuration (3rd) -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="SYSTEM CONFIGURATION" FontWeight="Bold" Foreground="#89B4FA" Margin="0,0,0,10"/>
                    <CheckBox Name="ChkStartup" Content="Run Backup on Windows Start Up" Foreground="White"/>
                </StackPanel>
            </Border>

            <!-- System Information (4th) -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="SYSTEM INFORMATION" FontWeight="Bold" Foreground="#CBA6F7" Margin="0,0,0,10"/>
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="App Version:" Foreground="#A6ADC8" Width="120"/>
                        <TextBlock Grid.Column="1" Name="TxtVersion" Text="v..." FontWeight="Bold"/>
                    </Grid>
                    <Grid ColumnDefinitions="Auto, *">
                        <TextBlock Text="Created By:" Foreground="#A6ADC8" Width="120"/>
                        <TextBlock Grid.Column="1" Name="TxtCreator" Text="Wesley" FontWeight="Bold"/>
                    </Grid>
                    <Button Name="BtnShowSystemInfo" Content="VIEW CHANGELOG &amp; BUILD INFO" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                            Background="#313244" Foreground="White" FontWeight="Bold" Padding="10" CornerRadius="8" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <!-- Credentials & Paths (5th) -->
            <Border Background="#1E1E2E" CornerRadius="12" Padding="20">
                <StackPanel Spacing="10">
                    <TextBlock Text="CREDENTIALS &amp; PATHS" FontWeight="Bold" Foreground="#89DCEB" Margin="0,0,0,10"/>

                    <TextBlock Text="Shared Host/IP" Foreground="#A6ADC8" FontWeight="Bold"/>
                    <TextBox Name="TxtSharedHost" Watermark="Server IP or Hostname (used for FTP &amp; SQL)"/>

                    <TextBlock Text="Shared TLS Fingerprint" Foreground="#A6ADC8" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Name="TxtSharedTls" Watermark="TLS/SSH Host Key Fingerprint (used for FTP &amp; SQL)"/>

                    <TextBlock Text="Local Paths" Foreground="#A6ADC8" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Name="TxtFtpLocalFolder" Watermark="FTP Local Folder"/>
                    <TextBox Name="TxtMailchimpFolder" Watermark="Mailchimp Folder"/>
                    <TextBox Name="TxtSqlLocalFolder" Watermark="SQL Local Folder"/>

                    <TextBlock Text="FTP (uses Shared Host)" Foreground="#A6ADC8" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Name="TxtFtpUser" Watermark="FTP User"/>
                    <TextBox Name="TxtFtpPassword" Watermark="FTP Password" PasswordChar="●"/>
                    <TextBox Name="TxtFtpPort" Watermark="FTP Port (default 21)"/>

                    <TextBlock Text="SQL (uses Shared Host)" Foreground="#A6ADC8" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Name="TxtSqlUser" Watermark="SQL User"/>
                    <TextBox Name="TxtSqlPassword" Watermark="SQL Password" PasswordChar="●"/>
                    <TextBlock Text="Remote Path: /public_html/mysql_staged" Foreground="#6C7086" FontSize="11" FontStyle="Italic"/>

                    <TextBlock Text="Mailchimp" Foreground="#A6ADC8" FontWeight="Bold" Margin="0,8,0,0"/>
                    <TextBox Name="TxtMcApiKey" Watermark="Mailchimp API Key" PasswordChar="●"/>
                    <TextBox Name="TxtMcAudienceId" Watermark="Mailchimp Audience Id"/>

                    <Button Name="BtnSaveConfig" Classes="Primary Settings" Content="SAVE CONFIG" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,10,0,0"/>
                    <TextBlock Name="TxtConfigStatus" Text="" Foreground="#A6ADC8" FontStyle="Italic" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
