<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.AdminChangePasswordDialog"
             Width="400">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30" VerticalAlignment="Top">
        <StackPanel Spacing="15" VerticalAlignment="Top">
            <TextBlock Name="TxtTitle" Text="Change Password" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center"/>
            
            <TextBlock Name="TxtForUser" Text="" Foreground="{DynamicResource AccentWebsite}" FontSize="12" HorizontalAlignment="Center"/>
            
            <TextBlock Text="New Password" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
            <TextBox Name="TxtNewPassword" PasswordChar="●" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
            
            <TextBlock Text="Confirm New Password" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
            <TextBox Name="TxtConfirmPassword" PasswordChar="●" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
            
            <TextBlock Name="TxtError" Text="" Foreground="{DynamicResource AppWarning}" FontSize="11" TextWrapping="Wrap" IsVisible="False"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="20,10" CornerRadius="8"/>
                <Button Name="BtnChange" Content="Change Password" Background="{DynamicResource AccentWebsite}" Foreground="#000000" Padding="20,10" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
