<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.AdminChangePasswordDialog"
             Width="400" Height="340">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#45475A" BorderThickness="1" Padding="30">
        <StackPanel Spacing="15">
            <TextBlock Name="TxtTitle" Text="Change Password" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4" HorizontalAlignment="Center"/>
            
            <TextBlock Name="TxtForUser" Text="" Foreground="#A6ADC8" FontSize="12" HorizontalAlignment="Center"/>
            
            <TextBlock Text="New Password" Foreground="#A6ADC8" FontSize="12"/>
            <TextBox Name="TxtNewPassword" PasswordChar="●" Background="#313244" Foreground="#CDD6F4" CornerRadius="8" Padding="10"/>
            
            <TextBlock Text="Confirm New Password" Foreground="#A6ADC8" FontSize="12"/>
            <TextBox Name="TxtConfirmPassword" PasswordChar="●" Background="#313244" Foreground="#CDD6F4" CornerRadius="8" Padding="10"/>
            
            <TextBlock Name="TxtError" Text="" Foreground="#F38BA8" FontSize="11" TextWrapping="Wrap"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,15,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="#45475A" Foreground="#CDD6F4" Padding="20,10" CornerRadius="8"/>
                <Button Name="BtnChange" Content="Change Password" Background="#CBA6F7" Foreground="#1E1E2E" Padding="20,10" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
