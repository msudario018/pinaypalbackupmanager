<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PinayPalBackupManager.UI.UserControls.TabOrderDialog"
        Width="360"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBg}"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="0">

    <Grid RowDefinitions="Auto, *, Auto" Margin="24">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,18">
            <TextBlock Text="Customize Tab Order" FontSize="17" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
            <TextBlock Text="Use the arrows to reorder navigation tabs." FontSize="11" Foreground="{DynamicResource AppMuted}"/>
        </StackPanel>

        <!-- Tab List -->
        <Border Grid.Row="1" Background="{DynamicResource AppCard}" CornerRadius="12" Padding="16">
            <StackPanel Name="TabList" Spacing="6"/>
        </Border>

        <!-- Footer -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto, 10, Auto" Margin="0,18,0,0">
            <Button Grid.Column="0" Name="BtnResetOrder" Content="Reset to Default" Background="{DynamicResource AppSurface}" Foreground="{DynamicResource AppWarning}" BorderThickness="0" CornerRadius="8" Padding="14,10" FontSize="11" Cursor="Hand"/>
            <Button Grid.Column="1" Name="BtnCancelOrder" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppSubtext}" BorderThickness="0" CornerRadius="8" Padding="20,10" FontSize="12" Cursor="Hand"/>
            <Button Grid.Column="3" Name="BtnSaveOrder" Content="Apply Order" Background="{DynamicResource AccentWebsite}" Foreground="#000000" BorderThickness="0" CornerRadius="8" Padding="20,10" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
        </Grid>

    </Grid>
</Window>
