<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.AdminChangeUsernameDialog"
             Width="400">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30" VerticalAlignment="Top">
        <StackPanel Spacing="15" VerticalAlignment="Top">
            <TextBlock Text="Change Username" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center"/>
            
            <TextBlock Name="TxtCurrent" Text="" Foreground="{DynamicResource AppSubtext}" FontSize="12" HorizontalAlignment="Center"/>
            
            <TextBlock Text="New Username" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
            <TextBox Name="TxtNewUsername" Background="{DynamicResource AppSurface}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
            
            <TextBlock Name="TxtError" Text="" Foreground="{DynamicResource AccentError}" FontSize="11" TextWrapping="Wrap" IsVisible="False"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="15,8" CornerRadius="8"/>
                <Button Name="BtnChange" Content="Change Username" Background="{DynamicResource AccentDefault}" Foreground="{DynamicResource AppText}" Padding="15,8" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
