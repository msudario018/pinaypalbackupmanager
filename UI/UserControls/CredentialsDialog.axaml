<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.CredentialsDialog"
             Width="500" Height="600">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#45475A" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,25">
                <PathIcon Data="M12,17A2,2 0 0,1 14,19A2,2 0 0,1 12,21A2,2 0 0,1 10,19A2,2 0 0,1 12,17M12,15.5C13.5,15.5 14.5,16.5 14.5,17.5C14.5,18.5 13.5,19.5 12,19.5C10.5,19.5 9.5,18.5 9.5,17.5C9.5,16.5 10.5,15.5 12,15.5M12,4C14.5,4 16.5,5.5 17.3,8H17.3C17.5,8.5 18,9 18.6,9H19C20.1,9 21,9.9 21,11C21,12.1 20.1,13 19,13H17.3C17.3,13.2 17.2,13.5 17.1,13.7L15.7,15.8C15.4,16.2 15,16.4 14.5,16.4H9.5C9,16.4 8.6,16.2 8.3,15.8L6.9,13.7C6.8,13.5 6.7,13.2 6.7,13H5C3.9,13 3,12.1 3,11C3,9.9 3.9,9 5,9H5.4C6,9 6.5,8.5 6.7,8H6.7C7.5,5.5 9.5,4 12,4Z" 
                        Width="32" Height="32" Foreground="#89B4FA"/>
                <TextBlock Text="Credentials" FontSize="22" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15">
                    <!-- Hidden fields for pre-filled values -->
                    <TextBox Name="TxtSharedHost" IsVisible="False" Text="148.72.60.215"/>
                    <TextBox Name="TxtSharedTls" IsVisible="False" Text="SHA256:72:87:45:50:b8:1e:bd:75:10:f8:87:a0:03:2f:4d:f5:3b:41:7a:8e"/>
                    <TextBox Name="TxtFtpUser" IsVisible="False" Text="backupuser@pinaypal.net"/>
                    <TextBox Name="TxtFtpPort" IsVisible="False" Text="21"/>
                    <TextBox Name="TxtSqlUser" IsVisible="False" Text="z2fe7z1ysonk"/>
                    <TextBox Name="TxtMcAudienceId" IsVisible="False" Text="714bb33d4c"/>

                    <Border Background="#313244" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="FTP Password" Foreground="#F9E2AF" FontWeight="Bold"/>
                            <TextBox Name="TxtFtpPassword" Watermark="Enter FTP password" PasswordChar="●" Background="#1E1E2E" Foreground="#CDD6F4" CornerRadius="8" Padding="10"/>
                            <TextBlock Text="Host and username pre-configured" Foreground="#6C7086" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#313244" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="SQL Password" Foreground="#A6E3A1" FontWeight="Bold"/>
                            <TextBox Name="TxtSqlPassword" Watermark="Enter SQL password" PasswordChar="●" Background="#1E1E2E" Foreground="#CDD6F4" CornerRadius="8" Padding="10"/>
                            <TextBlock Text="Host and username pre-configured" Foreground="#6C7086" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Background="#313244" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Mailchimp API Key" Foreground="#CBA6F7" FontWeight="Bold"/>
                            <TextBox Name="TxtMcApiKey" Watermark="Enter Mailchimp API Key" PasswordChar="●" Background="#1E1E2E" Foreground="#CDD6F4" CornerRadius="8" Padding="10"/>
                            <TextBlock Text="Audience ID pre-configured" Foreground="#6C7086" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Name="TxtStatus" Text="" Foreground="#F38BA8" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,20,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="#45475A" Foreground="#CDD6F4" Padding="25,12" CornerRadius="8" FontWeight="SemiBold"/>
                <Button Name="BtnSave" Content="Save Credentials" Background="#89B4FA" Foreground="#1E1E2E" Padding="25,12" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
