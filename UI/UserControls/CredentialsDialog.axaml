<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.CredentialsDialog"
             Width="500" Height="600">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,25">
                <PathIcon Data="M12,17A2,2 0 0,1 14,19A2,2 0 0,1 12,21A2,2 0 0,1 10,19A2,2 0 0,1 12,17M12,15.5C13.5,15.5 14.5,16.5 14.5,17.5C14.5,18.5 13.5,19.5 12,19.5C10.5,19.5 9.5,18.5 9.5,17.5C9.5,16.5 10.5,15.5 12,15.5M12,4C14.5,4 16.5,5.5 17.3,8H17.3C17.5,8.5 18,9 18.6,9H19C20.1,9 21,9.9 21,11C21,12.1 20.1,13 19,13H17.3C17.3,13.2 17.2,13.5 17.1,13.7L15.7,15.8C15.4,16.2 15,16.4 14.5,16.4H9.5C9,16.4 8.6,16.2 8.3,15.8L6.9,13.7C6.8,13.5 6.7,13.2 6.7,13H5C3.9,13 3,12.1 3,11C3,9.9 3.9,9 5,9H5.4C6,9 6.5,8.5 6.7,8H6.7C7.5,5.5 9.5,4 12,4Z" 
                        Width="32" Height="32" Foreground="#89B4FA"/>
                <TextBlock Text="Credentials" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15">
                    <TextBlock Text="Shared Host/IP" Foreground="{DynamicResource AppSubtext}" FontWeight="Bold"/>
                    <TextBox Name="TxtSharedHost" Watermark="Server IP or Hostname (used for FTP &amp; SQL)" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>

                    <TextBlock Text="Shared TLS Fingerprint" Foreground="{DynamicResource AppSubtext}" FontWeight="Bold"/>
                    <TextBox Name="TxtSharedTls" Watermark="TLS/SSH Host Key Fingerprint" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>

                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15" Margin="0,10,0,0">
                        <StackPanel Spacing="10">
                            <TextBlock Text="FTP Settings" Foreground="#F9E2AF" FontWeight="Bold"/>
                            <TextBox Name="TxtFtpUser" Watermark="FTP Username" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                            <TextBox Name="TxtFtpPassword" Watermark="FTP Password" PasswordChar="●" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                            <TextBox Name="TxtFtpPort" Watermark="FTP Port (default 21)" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="SQL Settings" Foreground="#A6E3A1" FontWeight="Bold"/>
                            <TextBox Name="TxtSqlUser" Watermark="SQL Username" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                            <TextBox Name="TxtSqlPassword" Watermark="SQL Password" PasswordChar="●" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                            <TextBlock Text="Remote Path: /public_html/mysql_staged" Foreground="{DynamicResource AppMuted}" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Mailchimp Settings" Foreground="#CBA6F7" FontWeight="Bold"/>
                            <TextBox Name="TxtMcApiKey" Watermark="Mailchimp API Key" PasswordChar="●" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                            <TextBox Name="TxtMcAudienceId" Watermark="Mailchimp Audience ID" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Name="TxtStatus" Text="" Foreground="#F38BA8" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,20,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="25,12" CornerRadius="8" FontWeight="SemiBold"/>
                <Button Name="BtnSave" Content="Save Credentials" Background="#89B4FA" Foreground="#1E1E2E" Padding="25,12" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
