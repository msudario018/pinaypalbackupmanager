<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.SystemInfoDialog"
             Width="500" Height="400">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <TextBlock Grid.Row="0" Text="System Information" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center" Margin="0,0,0,20"/>
            
            <!-- Content -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="15">
                    <TextBlock Name="TxtBuildInfo" Text="" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
                    
                    <Border Background="{DynamicResource AppSurface}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CHANGELOG" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource AccentWebsite}"/>
                            <TextBlock Name="TxtChangelog" Text="" Foreground="{DynamicResource AppText}" FontSize="11" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Button -->
            <Button Grid.Row="2" Name="BtnOk" Content="OK" Background="{DynamicResource AccentWebsite}" Foreground="{DynamicResource AppText}" Padding="30,10" CornerRadius="8" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20,0,0"/>
        </Grid>
    </Border>
</UserControl>
