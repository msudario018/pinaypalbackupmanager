<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.ConfirmDialog"
             Width="400" Height="200">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Name="TitleText" Text="Confirm" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center"/>
            </StackPanel>
            
            <!-- Content -->
            <TextBlock Grid.Row="1" Name="MessageText" Text="Are you sure?" FontSize="14" Foreground="{DynamicResource AppText}" TextWrapping="Wrap" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,20,0,0">
                <Button Name="BtnNo" Content="No" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="25,12" CornerRadius="8" FontWeight="SemiBold"/>
                <Button Name="BtnYes" Content="Yes" Background="{DynamicResource AccentWebsite}" Foreground="#000000" Padding="25,12" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
