<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.UpdateAvailableDialog"
             Width="450" Height="350">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#45475A" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="Auto, *, Auto, Auto">
            <!-- Header with Icon -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,15">
                <PathIcon Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M11,17H13V11H11V17Z" 
                        Width="32" Height="32" Foreground="#F9E2AF"/>
                <TextBlock Text="Update Available" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Version Info -->
            <TextBlock Grid.Row="1" Name="TxtVersion" Text="Version: v2.6.14" FontSize="16" FontWeight="SemiBold" 
                       Foreground="#89B4FA" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            
            <!-- Changelog Content -->
            <Border Grid.Row="2" Background="#11111B" CornerRadius="8" Padding="15" Margin="0,0,0,20">
                <ScrollViewer VerticalScrollBarVisibility="Auto" MaxHeight="150">
                    <StackPanel Spacing="8">
                        <TextBlock Text="What's New:" FontSize="12" FontWeight="Bold" Foreground="#A6E3A1"/>
                        <TextBlock Name="TxtChangelog" Text="" Foreground="#CDD6F4" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="15" HorizontalAlignment="Center">
                <Button Name="BtnYes" Content="Yes" Background="#A6E3A1" Foreground="#1E1E2E" 
                        Padding="40,10" CornerRadius="8" FontWeight="Bold"/>
                <Button Name="BtnNo" Content="No" Background="#45475A" Foreground="#CDD6F4" 
                        Padding="40,10" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
