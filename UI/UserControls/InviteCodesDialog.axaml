<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.InviteCodesDialog"
             Width="450" Height="300">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#45475A" BorderThickness="1" Padding="25">
        <Grid RowDefinitions="Auto, Auto, *, Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,20">
                <PathIcon Data="M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11L21.54,9.37C21.73,9.71 21.88,10.08 22,10.46L20.95,12.96C20.84,12.65 20.7,12.34 20.53,12.03C20.7,11.72 20.84,11.41 20.95,11.11L22,13.61C21.88,13.99 21.73,14.36 21.54,14.71L19.43,13.07C19.47,12.75 19.5,12.43 19.5,12.12C19.5,11.8 19.47,11.47 19.43,11.15L21.54,9.52C21.73,9.86 21.88,10.23 22,10.61L20.95,13.11C20.84,12.8 20.7,12.5 20.53,12.18C20.7,11.87 20.84,11.56 20.95,11.25L22,13.75C21.88,14.13 21.73,14.5 21.54,14.85L19.43,13.21C19.47,12.89 19.5,12.57 19.5,12.25C19.5,11.93 19.47,11.6 19.43,11.28L21.54,9.65C21.73,9.99 21.88,10.36 22,10.74L20.95,13.24C20.84,12.93 20.7,12.62 20.53,12.31C20.7,12 20.84,11.69 20.95,11.38L22,13.88C21.88,14.26 21.73,14.63 21.54,14.98L19.43,13.34Z" 
                        Width="28" Height="28" Foreground="#F9E2AF"/>
                <TextBlock Text="Invite Codes" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Timer Arc -->
            <Grid Grid.Row="1" HorizontalAlignment="Center" Margin="0,0,0,15">
                <PathIcon Data="M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M12,4A8,8 0 0,1 20,12A8,8 0 0,1 12,20A8,8 0 0,1 4,12A8,8 0 0,1 12,4Z" 
                         Width="16" Height="16" Foreground="#313244"/>
                <Path Name="TimerArc" Data="M 8,1 A 7,7 0 1,1 8,15" 
                      Stroke="#89B4FA" StrokeThickness="2" Fill="Transparent"/>
            </Grid>
            
            <!-- Invite Code Display -->
            <Border Grid.Row="2" Background="#11111B" CornerRadius="8" Padding="20">
                <Grid ColumnDefinitions="*, Auto, Auto">
                    <TextBox Grid.Column="0" Name="TxtInviteCode" IsReadOnly="True" 
                             Background="Transparent" BorderThickness="0" 
                             FontSize="18" FontWeight="Bold" Foreground="#A6E3A1" 
                             HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    <Button Grid.Column="1" Name="BtnCopy" Classes="Ghost" Margin="10,0,0,0">
                        <PathIcon Data="M19,21H8V7H19M19,5H8A2,2 0 0,0 6,7V21A2,2 0 0,0 8,23H19A2,2 0 0,0 21,21V7A2,2 0 0,0 19,5M16,1H4A2,2 0 0,0 2,3V17H4V3H16V1Z" 
                                Width="16" Height="16" Foreground="#89B4FA"/>
                    </Button>
                    <Button Grid.Column="2" Name="BtnRegenerate" Classes="Ghost" Margin="5,0,0,0">
                        <PathIcon Data="M12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6A6,6 0 0,1 18,12A6,6 0 0,1 12,18M12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4M12,2L12,4L12,2M12,20L12,22L12,20M4.93,4.93L6.34,6.34L4.93,4.93M17.66,17.66L19.07,19.07L17.66,17.66M2,12L4,12L2,12M20,12L22,12L20,12M4.93,19.07L6.34,17.66L4.93,19.07M17.66,6.34L19.07,4.93L17.66,6.34Z" 
                                Width="16" Height="16" Foreground="#F9E2AF"/>
                    </Button>
                </Grid>
            </Border>
            
            <!-- Close Button -->
            <Button Grid.Row="3" Name="BtnClose" Content="Close" Classes="SecondaryBtn" HorizontalAlignment="Center" Margin="0,20,0,0" Padding="40,10"/>
        </Grid>
    </Border>
</UserControl>
