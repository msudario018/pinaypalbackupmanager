<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.SqlControl">
    <Grid RowDefinitions="Auto, Auto, Auto, *, Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AccentSqlBg}" Padding="20" CornerRadius="16" Margin="0,0,0,15" ClipToBounds="True" BorderBrush="{DynamicResource AccentSql}" BorderThickness="1">
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                <TextBlock Grid.Row="0" Name="TxtStatus" Text="READY" FontSize="24" FontWeight="Bold" Foreground="{DynamicResource AccentSqlLight}" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,20,0"/>

                <TextBlock Grid.Row="1" Name="TxtFile" Text="Status: Idle" Foreground="{DynamicResource AccentSqlMuted}" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,12">
                    <Border Background="{DynamicResource AccentSqlDark}" CornerRadius="20" Padding="15,7">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentSqlLight}"/>
                            <TextBlock Name="TxtAutoScan" Text="Auto-Scan: --:--:--" Foreground="{DynamicResource AccentSqlLight}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AccentSqlDark}" CornerRadius="20" Padding="15,7">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentSqlLight}"/>
                            <TextBlock Name="TxtNextDaily" Text="Next Daily: --:--:--" Foreground="{DynamicResource AccentSqlLight}" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Name="BtnStart" Classes="Primary Sql" Content="START SQL BACKUP"/>
                    <Button Name="BtnCancel" Classes="Danger" Content="CANCEL" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <ProgressBar Grid.Row="1" Name="ProgressBar" Height="10" Margin="0,0,0,15" CornerRadius="5" Background="{DynamicResource AccentSqlDark}" Foreground="{DynamicResource AccentSql}"/>

        <!-- Utility Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15" HorizontalAlignment="Right">
            <Button Name="BtnSyncCheck" Classes="Secondary" Content="Sync Check"/>
            <Button Name="BtnTest" Classes="Secondary" Content="Test Connection"/>
            <Button Name="BtnClear" Classes="Secondary" Content="Clear"/>
        </StackPanel>

        <!-- Logs Container -->
        <Border Grid.Row="3" Background="{DynamicResource AccentSqlBg}" CornerRadius="16" Padding="15" BorderBrush="{DynamicResource AccentSql}" BorderThickness="1">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Text="TERMINAL LOGS" FontWeight="Bold" Foreground="{DynamicResource AccentSqlLight}" VerticalAlignment="Center" Margin="0,0,0,10"/>
                <TextBox Grid.Row="1" Name="TxtLogs" IsReadOnly="True" Background="Transparent" BorderThickness="0" CornerRadius="12" FontFamily="Consolas" Foreground="{DynamicResource AppLogText}" FontSize="12" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="4" Name="BtnViewLog" Content="OPEN LOG FILE" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                Background="{DynamicResource AppBorder}" Margin="0,15,0,0" Padding="10" CornerRadius="12"/>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBox#TxtLogs">
            <Setter Property="Foreground" Value="{DynamicResource AppLogText}"/>
        </Style>
        <Style Selector="TextBox#TxtLogs:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox#TxtLogs:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentSql}"/>
            <Setter Property="BorderThickness" Value="2"/>
        </Style>

        <Style Selector="Button.ToolBtn">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="Background" Value="{DynamicResource AccentSqlLight}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ToolBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSql}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.ToolBtn:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentSqlDark}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button#BtnStart">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnStart:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSql}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button#BtnStart:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentSqlDark}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button#BtnCancel">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnCancel:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button#BtnCancel:pressed">
            <Setter Property="Background" Value="{DynamicResource AppMuted}"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button#BtnViewLog">
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="{DynamicResource AccentSqlLight}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnViewLog:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentSql}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(1.01)"/>
        </Style>
        <Style Selector="Button#BtnViewLog:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentSqlDark}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(0.99)"/>
        </Style>
    </UserControl.Styles>
</UserControl>
