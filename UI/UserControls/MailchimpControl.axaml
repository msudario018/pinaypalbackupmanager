<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.MailchimpControl">
    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppCard}" Padding="20" CornerRadius="12" Margin="0,0,0,15" ClipToBounds="True">
            <Grid ColumnDefinitions="*, Auto" RowDefinitions="Auto, Auto">
                <TextBlock Grid.Row="0" Name="TxtStatus" Text="READY" FontSize="24" FontWeight="Bold" Foreground="#89DCEB" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,20,0"/>

                <TextBlock Grid.Row="1" Name="TxtFile" Text="Status: Idle" Foreground="{DynamicResource AppSubtext}" TextWrapping="Wrap" TextTrimming="None" Margin="0,0,20,0"/>

                <StackPanel Grid.Column="1" Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="0,0,0,12">
                    <Border Background="{DynamicResource AppTimerAutoScan}" CornerRadius="20" Padding="15,7">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#FAB387"/>
                            <TextBlock Name="TxtAutoScan" Text="Auto-Scan: --:--:--" Foreground="#FAB387" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <Border Background="{DynamicResource AppTimerDaily}" CornerRadius="20" Padding="15,7">
                        <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <Ellipse Width="8" Height="8" Fill="#89B4FA"/>
                            <TextBlock Name="TxtNextDaily" Text="Next Daily: --:--:--" Foreground="#89B4FA" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <StackPanel Grid.Column="1" Grid.Row="1" Orientation="Horizontal" Spacing="10" HorizontalAlignment="Right">
                    <Button Name="BtnRunFull" Classes="Primary Mailchimp" Content="FULL BACKUP"/>
                    <Button Name="BtnCancel" Classes="Danger" Content="CANCEL" IsEnabled="False"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Progress -->
        <ProgressBar Grid.Row="1" Name="ProgressBar" Height="10" Margin="0,0,0,15" CornerRadius="5" Background="{DynamicResource AppBorder}" Foreground="#89DCEB"/>

        <!-- Utility Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="10" Margin="0,0,0,15" HorizontalAlignment="Right">
            <Button Name="BtnSyncCheck" Classes="Secondary" Content="Sync Check"/>
            <Button Name="BtnClear" Classes="Secondary" Content="Clear"/>
        </StackPanel>

        <Border Grid.Row="3" Background="{DynamicResource AppSurface}" CornerRadius="12" Padding="15" Margin="0,0,0,15">
            <Grid RowDefinitions="Auto, Auto">
                <TextBlock Grid.Row="0" Text="MAILCHIMP INDIVIDUAL BACKUP" Foreground="{DynamicResource AppSubtext}" FontWeight="Bold" FontSize="11" Margin="0,0,0,10"/>
                <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <Button Name="BtnMembers" Classes="Secondary" Content="Members"/>
                    <Button Name="BtnCampaigns" Classes="Secondary" Content="Campaigns"/>
                    <Button Name="BtnReports" Classes="Secondary" Content="Reports"/>
                    <Button Name="BtnMergeFields" Classes="Secondary" Content="Merge Fields"/>
                    <Button Name="BtnTags" Classes="Secondary" Content="Tags"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Logs Container -->
        <Border Grid.Row="4" Background="{DynamicResource AppSurface}" CornerRadius="12" Padding="15">
            <Grid RowDefinitions="Auto, *">
                <TextBlock Text="TERMINAL LOGS" FontWeight="Bold" Foreground="{DynamicResource AppSubtext}" Margin="0,0,0,10"/>

                <TextBox Grid.Row="1" Name="TxtLogs" IsReadOnly="True" Background="Transparent" BorderThickness="0"
                         FontFamily="Consolas" Foreground="{DynamicResource AppLogText}" FontSize="12" AcceptsReturn="True" TextWrapping="Wrap"
                         ScrollViewer.VerticalScrollBarVisibility="Visible" ScrollViewer.HorizontalScrollBarVisibility="Disabled"/>
            </Grid>
        </Border>

        <!-- Footer -->
        <Button Grid.Row="5" Name="BtnViewLog" Content="OPEN LOG FILE" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" 
                Background="{DynamicResource AppBorder}" Margin="0,15,0,0" Padding="10" CornerRadius="8"/>
    </Grid>

    <UserControl.Styles>
        <Style Selector="TextBox#TxtLogs">
            <Setter Property="Foreground" Value="{DynamicResource AppLogText}"/>
        </Style>
        <Style Selector="TextBox#TxtLogs:pointerover /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>
        <Style Selector="TextBox#TxtLogs:focus /template/ Border#PART_BorderElement">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
        </Style>

        <Style Selector="Button.ToolBtn">
            <Setter Property="Padding" Value="12,5"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="6"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ToolBtn:pointerover">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.ToolBtn:pressed">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button.ManualBtn">
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="MinWidth" Value="110"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.ManualBtn:pointerover">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="RenderTransform" Value="scale(1.05)"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style Selector="Button.ManualBtn:pressed">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="RenderTransform" Value="scale(0.95)"/>
        </Style>

        <Style Selector="Button#BtnRunFull">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnRunFull:pointerover">
            <Setter Property="Background" Value="#C2F0F7"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button#BtnRunFull:pressed">
            <Setter Property="Background" Value="#86C8D1"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button#BtnCancel">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnCancel:pointerover">
            <Setter Property="Background" Value="#F8B1C4"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button#BtnCancel:pressed">
            <Setter Property="Background" Value="#E37A92"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button#BtnViewLog">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.2"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button#BtnViewLog:pointerover">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="RenderTransform" Value="scale(1.01)"/>
        </Style>
        <Style Selector="Button#BtnViewLog:pressed">
            <Setter Property="Background" Value="#585B70"/>
            <Setter Property="RenderTransform" Value="scale(0.99)"/>
        </Style>
    </UserControl.Styles>
</UserControl>
