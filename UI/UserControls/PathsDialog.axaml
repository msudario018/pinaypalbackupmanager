<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.PathsDialog"
             Width="500" Height="450">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30">
        <Grid RowDefinitions="*, Auto">
            <!-- Content -->
            <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="20">
                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="FTP Backup Path" Foreground="{DynamicResource AccentWarning}" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" Name="TxtFtpLocalFolder" Watermark="C:\Backups\FTP" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                                <Button Grid.Column="1" Name="BtnBrowseFtp" Margin="8,2,0,2"
                                        Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8"
                                        Padding="14,8" ToolTip.Tip="Browse for folder" Cursor="Hand">
                                    <PathIcon Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                                              Width="18" Height="18"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Local folder where FTP backups will be stored" Foreground="{DynamicResource AppMuted}" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Mailchimp Backup Path" Foreground="{DynamicResource AccentSuccess}" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" Name="TxtMailchimpFolder" Watermark="C:\Backups\Mailchimp" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                                <Button Grid.Column="1" Name="BtnBrowseMailchimp" Margin="8,2,0,2"
                                        Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8"
                                        Padding="14,8" ToolTip.Tip="Browse for folder" Cursor="Hand">
                                    <PathIcon Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                                              Width="18" Height="18"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Local folder where Mailchimp backups will be stored" Foreground="{DynamicResource AppMuted}" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource AppBorder}" CornerRadius="8" Padding="15">
                        <StackPanel Spacing="10">
                            <TextBlock Text="SQL Backup Path" Foreground="{DynamicResource AccentWebsite}" FontWeight="Bold"/>
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBox Grid.Column="0" Name="TxtSqlLocalFolder" Watermark="C:\Backups\SQL" Background="{DynamicResource AppCard}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
                                <Button Grid.Column="1" Name="BtnBrowseSql" Margin="8,2,0,2"
                                        Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8"
                                        Padding="14,8" ToolTip.Tip="Browse for folder" Cursor="Hand">
                                    <PathIcon Data="M20,18H4V8H20M20,6H12L10,4H4C2.89,4 2,4.89 2,6V18A2,2 0 0,0 4,20H20A2,2 0 0,0 22,18V8C22,6.89 21.1,6 20,6Z"
                                              Width="18" Height="18"/>
                                </Button>
                            </Grid>
                            <TextBlock Text="Local folder where SQL backups will be stored" Foreground="{DynamicResource AppMuted}" FontSize="11" FontStyle="Italic"/>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Name="TxtStatus" Text="" Foreground="{DynamicResource AccentError}" FontSize="12" TextWrapping="Wrap"/>
                </StackPanel>
            </ScrollViewer>
            
            <!-- Buttons -->
            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="15" Margin="0,20,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="25,12" CornerRadius="8" FontWeight="SemiBold"/>
                <Button Name="BtnSave" Content="Save Paths" Background="{DynamicResource AccentSuccess}" Foreground="{DynamicResource AppText}" Padding="25,12" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
