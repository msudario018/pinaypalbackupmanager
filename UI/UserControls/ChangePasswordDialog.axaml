<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.ChangePasswordDialog"
             Width="400" Height="300">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1">
        <Grid RowDefinitions="Auto, *, Auto" Padding="30">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="Change Password" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4"/>
                <TextBlock Text="Enter your current password and new password" FontSize="12" Foreground="#6C7086"/>
            </StackPanel>
            
            <!-- Form -->
            <StackPanel Grid.Row="1" Spacing="16" Margin="0,20,0,0">
                <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="120, *">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Current:" VerticalAlignment="Center" Foreground="#A6ADC8"/>
                    <PasswordBox Grid.Row="0" Grid.Column="1" x:Name="TxtCurrentPassword" Watermark="Enter current password" 
                                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>
                    
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="New Password:" VerticalAlignment="Center" Foreground="#A6ADC8" Margin="0,16,0,0"/>
                    <PasswordBox Grid.Row="1" Grid.Column="1" x:Name="TxtNewPassword" Watermark="Enter new password (min 4 chars)" 
                                 Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A" Margin="0,16,0,0"/>
                </Grid>
                
                <TextBlock x:Name="TxtError" Text="" Foreground="#F38BA8" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
            </StackPanel>
            
            <!-- Buttons -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Grid.Column="0" x:Name="BtnCancel" Content="Cancel" Background="#45475A" Foreground="#CDD6F4"
                        Padding="20,8" CornerRadius="8" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="BtnChange" Content="Change Password" Background="#89B4FA" Foreground="#0B0F17"
                        Padding="20,8" CornerRadius="8" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
