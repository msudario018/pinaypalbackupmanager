<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.UploadAvatarDialog"
             Width="400" Height="280">
    
    <Border Background="#1E1E2E" CornerRadius="12" BorderBrush="#313244" BorderThickness="1">
        <Grid RowDefinitions="Auto, *, Auto" Padding="30">
            <!-- Header -->
            <StackPanel Grid.Row="0" Spacing="8">
                <TextBlock Text="Upload Avatar" FontSize="20" FontWeight="Bold" Foreground="#CDD6F4"/>
                <TextBlock Text="Choose an image file for your profile avatar" FontSize="12" Foreground="#6C7086"/>
            </StackPanel>
            
            <!-- Form -->
            <StackPanel Grid.Row="1" Spacing="16" Margin="0,20,0,0">
                <!-- Avatar Preview -->
                <Border HorizontalAlignment="Center" CornerRadius="50" Width="80" Height="80" Background="#45475A">
                    <Ellipse x:Name="AvatarPreview" Width="76" Height="76" Fill="#313244">
                        <Ellipse.Effect>
                            <Avalonia.Media.DropShadowEffect OffsetX="0" OffsetY="2" BlurRadius="4" Opacity="0.3"/>
                        </Ellipse.Effect>
                    </Ellipse>
                </Border>
                
                <!-- File Selection -->
                <Grid ColumnDefinitions="*, Auto">
                    <TextBox Grid.Column="0" x:Name="TxtFilePath" IsReadOnly="True" Watermark="No file selected" 
                             Background="#313244" Foreground="#CDD6F4" BorderBrush="#45475A"/>
                    <Button Grid.Column="1" x:Name="BtnBrowse" Content="Browse..." Background="#89B4FA" Foreground="#0B0F17"
                            Padding="12,8" CornerRadius="8" Margin="8,0,0,0"/>
                </Grid>
                
                <TextBlock x:Name="TxtError" Text="" Foreground="#F38BA8" FontSize="11" Margin="0,8,0,0" TextWrapping="Wrap"/>
                <TextBlock Text="Supported formats: JPG, PNG, GIF (Max 2MB)" FontSize="10" Foreground="#6C7086" FontStyle="Italic"/>
            </StackPanel>
            
            <!-- Buttons -->
            <Grid Grid.Row="2" ColumnDefinitions="*, *" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Grid.Column="0" x:Name="BtnCancel" Content="Cancel" Background="#45475A" Foreground="#CDD6F4"
                        Padding="20,8" CornerRadius="8" Margin="0,0,8,0"/>
                <Button Grid.Column="1" x:Name="BtnUpload" Content="Upload" Background="#A6E3A1" Foreground="#0B0F17"
                        Padding="20,8" CornerRadius="8" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Border>
</UserControl>
