<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PinayPalBackupManager.UI.UserControls.ScheduleDialog"
        Title="Schedule Settings"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        ShowInTaskbar="False"
        Background="{DynamicResource AppBg}">

    <Grid RowDefinitions="Auto, *, Auto" Margin="24,24,24,24">

        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,20">
            <TextBlock Text="Schedule Settings" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
            <TextBlock Text="Changes take effect immediately and persist across restarts." FontSize="11" Foreground="{DynamicResource AppMuted}"/>
        </StackPanel>

        <!-- Content -->
        <StackPanel Grid.Row="1" Spacing="20">

            <!-- Daily Backup Time Section -->
            <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                    <TextBlock Text="DAILY BACKUP TIME" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppSubtext}" LetterSpacing="1"/>
                    <TextBlock Text="Manila time (MNL) — 12-hour format" FontSize="10" Foreground="{DynamicResource AppMuted}"/>
                </StackPanel>

                <!-- FTP Daily -->
                <Border Background="{DynamicResource AppCard}" CornerRadius="10" Padding="14,12">
                    <Grid ColumnDefinitions="Auto, *, Auto, 8, Auto, 12, Auto, 8, Auto">
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#A6E3A1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="FTP / Website" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Name="FtpDailyHour" Width="50" TextAlignment="Center" Watermark="12" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#A6E3A1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <TextBlock Grid.Column="3" Text=":" FontSize="18" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="4" Name="FtpDailyMinute" Width="50" TextAlignment="Center" Watermark="00" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#A6E3A1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <Border Grid.Column="6" Name="FtpAmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="FtpAmText" Text="AM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                        <Border Grid.Column="8" Name="FtpPmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="FtpPmText" Text="PM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- Mailchimp Daily -->
                <Border Background="{DynamicResource AppCard}" CornerRadius="10" Padding="14,12">
                    <Grid ColumnDefinitions="Auto, *, Auto, 8, Auto, 12, Auto, 8, Auto">
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#89DCEB" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="Mailchimp" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Name="McDailyHour" Width="50" TextAlignment="Center" Watermark="6" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#89DCEB" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <TextBlock Grid.Column="3" Text=":" FontSize="18" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="4" Name="McDailyMinute" Width="50" TextAlignment="Center" Watermark="00" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#89DCEB" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <Border Grid.Column="6" Name="McAmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="McAmText" Text="AM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                        <Border Grid.Column="8" Name="McPmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="McPmText" Text="PM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                    </Grid>
                </Border>

                <!-- SQL Daily -->
                <Border Background="{DynamicResource AppCard}" CornerRadius="10" Padding="14,12">
                    <Grid ColumnDefinitions="Auto, *, Auto, 8, Auto, 12, Auto, 8, Auto">
                        <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#F9E2AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock Grid.Column="1" Text="SQL / Database" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="2" Name="SqlDailyHour" Width="50" TextAlignment="Center" Watermark="5" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#F9E2AF" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <TextBlock Grid.Column="3" Text=":" FontSize="18" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        <TextBox Grid.Column="4" Name="SqlDailyMinute" Width="50" TextAlignment="Center" Watermark="00" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#F9E2AF" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                        <Border Grid.Column="6" Name="SqlAmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="SqlAmText" Text="AM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                        <Border Grid.Column="8" Name="SqlPmBtn" Background="{DynamicResource AppBorder}" CornerRadius="6" Padding="10,6" Cursor="Hand">
                            <TextBlock Name="SqlPmText" Text="PM" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppMuted}"/>
                        </Border>
                    </Grid>
                </Border>
            </StackPanel>

            <!-- Auto-Scan Interval Section -->
            <StackPanel Spacing="10">
                <StackPanel Spacing="2">
                    <TextBlock Text="AUTO-SCAN INTERVAL" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource AppSubtext}" LetterSpacing="1"/>
                    <TextBlock Text="How often each service is automatically checked (hours + minutes)" FontSize="10" Foreground="{DynamicResource AppMuted}"/>
                </StackPanel>

                <Border Background="{DynamicResource AppCard}" CornerRadius="10" Padding="14,16">
                    <StackPanel Spacing="14">

                        <!-- FTP Auto-Scan -->
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto">
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#A6E3A1" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="FTP / Website" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Name="FtpScanHours" Width="50" TextAlignment="Center" Watermark="3" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#A6E3A1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="3" Text="h" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBox Grid.Column="4" Name="FtpScanMinutes" Width="50" TextAlignment="Center" Watermark="00" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#A6E3A1" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="5" Text="m" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>

                        <Border Background="{DynamicResource AppBorder}" Height="1"/>

                        <!-- Mailchimp Auto-Scan -->
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto">
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#89DCEB" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="Mailchimp" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Name="McScanHours" Width="50" TextAlignment="Center" Watermark="2" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#89DCEB" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="3" Text="h" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBox Grid.Column="4" Name="McScanMinutes" Width="50" TextAlignment="Center" Watermark="00" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#89DCEB" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="5" Text="m" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>

                        <Border Background="{DynamicResource AppBorder}" Height="1"/>

                        <!-- SQL Auto-Scan -->
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto, Auto">
                            <Ellipse Grid.Column="0" Width="8" Height="8" Fill="#F9E2AF" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBlock Grid.Column="1" Text="SQL / Database" FontSize="12" Foreground="{DynamicResource AppSubtext}" VerticalAlignment="Center"/>
                            <TextBox Grid.Column="2" Name="SqlScanHours" Width="50" TextAlignment="Center" Watermark="2" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#F9E2AF" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="3" Text="h" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,6,0"/>
                            <TextBox Grid.Column="4" Name="SqlScanMinutes" Width="50" TextAlignment="Center" Watermark="15" FontSize="13" FontWeight="Bold" Background="{DynamicResource AppSurface}" Foreground="#F9E2AF" BorderBrush="{DynamicResource AppBorder}" CornerRadius="6" Padding="8,6"/>
                            <TextBlock Grid.Column="5" Text="m" FontSize="12" Foreground="{DynamicResource AppMuted}" VerticalAlignment="Center" Margin="6,0,0,0"/>
                        </Grid>

                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>

        <!-- Footer -->
        <Grid Grid.Row="2" ColumnDefinitions="*, Auto, 10, Auto, 10, Auto" Margin="0,20,0,0">
            <TextBlock Grid.Column="0" Name="DialogStatus" Text="" FontSize="10" Foreground="#A6E3A1" VerticalAlignment="Center"/>
            <Button Grid.Column="1" Name="BtnReset" Content="Reset to Default" Background="{DynamicResource AppBorder}" Foreground="#FAB387" BorderThickness="0" CornerRadius="8" Padding="14,10" FontSize="11" Cursor="Hand"/>
            <Button Grid.Column="3" Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppSubtext}" BorderThickness="0" CornerRadius="8" Padding="20,10" FontSize="12" Cursor="Hand"/>
            <Button Grid.Column="5" Name="BtnSave" Content="Save Changes" Background="#CBA6F7" Foreground="#1E1E2E" BorderThickness="0" CornerRadius="8" Padding="20,10" FontSize="12" FontWeight="Bold" Cursor="Hand"/>
        </Grid>

    </Grid>
</Window>
