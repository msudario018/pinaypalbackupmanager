<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.ChangeUsernameDialog"
             Width="400" Height="320">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="30">
        <StackPanel Spacing="15">
            <TextBlock Text="Change Username" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center"/>
            
            <TextBlock Text="Current Username" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
            <TextBlock Name="TxtCurrentUsername" Text="" Foreground="{DynamicResource AppText}" FontSize="14" FontWeight="SemiBold"/>
            
            <TextBlock Text="New Username" Foreground="{DynamicResource AppSubtext}" FontSize="12"/>
            <TextBox Name="TxtNewUsername" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" CornerRadius="8" Padding="10"/>
            
            <TextBlock Name="TxtError" Text="" Foreground="#F38BA8" FontSize="11" TextWrapping="Wrap"/>
            
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="10" Margin="0,10,0,0">
                <Button Name="BtnCancel" Content="Cancel" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="15,8" CornerRadius="8"/>
                <Button Name="BtnChange" Content="Change Username" Background="#89B4FA" Foreground="#1E1E2E" Padding="15,8" CornerRadius="8" FontWeight="Bold"/>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
