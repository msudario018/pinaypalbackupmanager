<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.LoginHistoryDialog">
    
        <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="24" Width="560">
            <StackPanel Spacing="15">
                <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,8">
                    <TextBlock Grid.Column="0" Text="Login History" FontSize="20" FontWeight="Bold" Foreground="{DynamicResource AppText}"/>
                    <Button Grid.Column="1" Name="BtnClear" Content="Clear" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" Padding="12,6" CornerRadius="6" FontSize="11"/>
                </Grid>
                
                <Border Background="{DynamicResource AppBg}" CornerRadius="8" Padding="10">
                    <ScrollViewer MaxHeight="320" VerticalScrollBarVisibility="Hidden">
                        <StackPanel Name="HistoryList" Spacing="8"/>
                    </ScrollViewer>
                </Border>
                
                <TextBlock Name="TxtEmpty" Text="No login history found." FontSize="12" Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center" IsVisible="False"/>
                
                <Button Name="BtnClose" Content="Close" Background="{DynamicResource AccentWebsite}" Foreground="{DynamicResource AppText}" Padding="20,10" CornerRadius="8" HorizontalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Border>
</UserControl>
