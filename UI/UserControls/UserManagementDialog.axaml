<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.UI.UserControls.UserManagementDialog"
             Width="900" Height="850">
    
    <Border Background="{DynamicResource AppCard}" CornerRadius="12" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" Padding="25">
        <Grid RowDefinitions="Auto, Auto, *, Auto">
            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" HorizontalAlignment="Center" Margin="0,0,0,20">
                <PathIcon Data="M16,13C15.71,13 15.38,13 15.03,13.05C16.19,13.89 17,15 17,16.5V19H23V16.5C23,14.17 18.33,13 16,13M8,13C5.67,13 1,14.17 1,16.5V19H15V16.5C15,14.17 10.33,13 8,13M8,11A3,3 0 0,0 11,8A3,3 0 0,0 8,5A3,3 0 0,0 5,8A3,3 0 0,0 8,11M16,11A3,3 0 0,0 19,8A3,3 0 0,0 16,5A3,3 0 0,0 13,8A3,3 0 0,0 16,11Z" 
                        Width="32" Height="32" Foreground="{DynamicResource AccentWebsite}"/>
                <TextBlock Text="User Management" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource AppText}" VerticalAlignment="Center"/>
            </StackPanel>
            
            <!-- Refresh Button -->
            <Button Grid.Row="1" Name="BtnRefresh" Background="{DynamicResource AccentWebsite}" Foreground="{DynamicResource AppText}" 
                    HorizontalAlignment="Right" Margin="0,0,0,15" Padding="16,8" CornerRadius="8" FontWeight="SemiBold">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z" 
                            Width="14" Height="14"/>
                    <TextBlock Text="Refresh" FontSize="12"/>
                </StackPanel>
            </Button>
            
            <!-- User List -->
            <Border Grid.Row="2" Background="{DynamicResource AppSurface}" CornerRadius="12" Padding="20" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Name="UserListPanel" Spacing="12">
                        <!-- Users will be added here dynamically -->
                    </StackPanel>
                </ScrollViewer>
            </Border>
            
            <!-- No Users Message -->
            <TextBlock Grid.Row="2" Name="TxtNoUsers" Text="No users found" FontSize="13" Foreground="{DynamicResource AppMuted}" 
                       HorizontalAlignment="Center" VerticalAlignment="Center" IsVisible="False" FontWeight="SemiBold"/>
            
            <!-- Close Button -->
            <Button Grid.Row="3" Name="BtnClose" Content="Close" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" 
                    HorizontalAlignment="Center" Margin="0,20,0,0" Padding="50,12" CornerRadius="8" FontWeight="SemiBold"/>
        </Grid>
    </Border>
</UserControl>
