<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PinayPalBackupManager.UI.MainWindow"
        Title="PinayPal Backup Manager"
        Width="1000" Height="850"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource AppBg}"
        Foreground="#CDD6F4"
        Icon="/Assets/logo.ico">
    
    <Grid ColumnDefinitions="72, *">
        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{DynamicResource AppSidebar}" BorderBrush="{DynamicResource AppBorder2}" BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto, *, Auto, Auto">

                <!-- Logo Area -->
                <Border Grid.Row="0" Padding="0,18,0,14" BorderBrush="#1E1E2E" BorderThickness="0,0,0,1">
                    <Image Source="/Assets/logo.ico" Width="34" Height="34" HorizontalAlignment="Center"/>
                </Border>

                <!-- Navigation Buttons -->
                <StackPanel Name="Sidebar" Grid.Row="1" Spacing="2" Margin="10,12,10,0" VerticalAlignment="Top">
                    <Button Classes="SideBtn" Tag="Home" ToolTip.Tip="Dashboard">
                        <PathIcon Data="{StaticResource HomeIcon}" Width="18" Height="18" Foreground="#585B70"/>
                    </Button>
                    <Rectangle Height="1" Fill="#1E1E2E" Margin="4,4"/>
                    <Button Classes="SideBtn" Tag="FTP" ToolTip.Tip="FTP Sync">
                        <PathIcon Data="{StaticResource CloudIcon}" Width="18" Height="18" Foreground="#585B70"/>
                    </Button>
                    <Button Classes="SideBtn" Tag="Mailchimp" ToolTip.Tip="Mailchimp">
                        <PathIcon Data="{StaticResource MailIcon}" Width="18" Height="18" Foreground="#585B70"/>
                    </Button>
                    <Button Classes="SideBtn" Tag="SQL" ToolTip.Tip="SQL Backup">
                        <PathIcon Data="{StaticResource DatabaseIcon}" Width="18" Height="18" Foreground="#585B70"/>
                    </Button>
                    <Rectangle Height="1" Fill="#1E1E2E" Margin="4,8"/>
                    <Button Classes="SideBtn" Tag="Settings" ToolTip.Tip="Settings">
                        <PathIcon Data="{StaticResource SettingsIcon}" Width="18" Height="18" Foreground="#585B70"/>
                    </Button>
                </StackPanel>

                <!-- Customize Tabs Button -->
                <Button Name="BtnCustomizeTabs" Grid.Row="2" Classes="SideBtn" ToolTip.Tip="Customize Tab Order"
                        HorizontalAlignment="Center" Margin="10,4,10,0" Cursor="Hand">
                    <PathIcon Data="M3,15H21V13H3V15M3,19H21V17H3V19M3,11H21V9H3V11M3,5V7H21V5H3Z"
                              Width="16" Height="16" Foreground="#585B70"/>
                </Button>

                <!-- Profile Section -->
                <Border Grid.Row="3" Padding="0,10" BorderBrush="#1E1E2E" BorderThickness="0,1,0,0">
                    <Button Name="BtnProfile" Background="Transparent" BorderThickness="0" Padding="4" HorizontalAlignment="Center"
                            CornerRadius="12" ToolTip.Tip="Profile" Cursor="Hand">
                        <Grid Width="36" Height="36">
                            <Ellipse Name="AvatarImageBg" Width="36" Height="36" Fill="#313244"/>
                            <Image Name="AvatarImage" Width="36" Height="36" Stretch="UniformToFill" IsVisible="False">
                                <Image.Clip>
                                    <EllipseGeometry Rect="0,0,36,36"/>
                                </Image.Clip>
                            </Image>
                        </Grid>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" RowDefinitions="Auto, *, Auto, Auto">
            <!-- Top Bar -->
            <Border Grid.Row="0" Height="54" Background="{DynamicResource AppTopBar}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*, *, *">
                    <!-- US Time Badge -->
                    <Border Grid.Column="0" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="22" HorizontalAlignment="Left" Margin="20,7" Padding="14,6">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <PathIcon Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                      Width="10" Height="10" Foreground="#A6ADC8"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="US (UTC-7)" Foreground="{DynamicResource AppSubtext}" FontSize="8" FontWeight="Bold"/>
                                <TextBlock Name="TxtUsTime" Text="--:--:--" FontSize="11" FontWeight="Heavy" Foreground="{DynamicResource AppText}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Manila Time Badge -->
                    <Border Grid.Column="1" Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="22" HorizontalAlignment="Center" Margin="0,7" Padding="14,6">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                            <PathIcon Data="M12,20A8,8 0 0,0 20,12A8,8 0 0,0 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20M12,2A10,10 0 0,1 22,12A10,10 0 0,1 12,22C6.47,22 2,17.5 2,12A10,10 0 0,1 12,2M12.5,7V12.25L17,14.92L16.25,16.15L11,13V7H12.5Z" 
                                      Width="10" Height="10" Foreground="{DynamicResource AppManilaTime}"/>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="MANILA (UTC+8)" Foreground="{DynamicResource AppManilaTime}" FontSize="8" FontWeight="Bold"/>
                                <TextBlock Name="TxtMnlTime" Text="--:--:--" FontSize="11" FontWeight="Heavy" Foreground="{DynamicResource AppManilaTime}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Theme Toggle + Bell + Version Badge -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="6" Margin="0,0,16,0">
                        <!-- Bell icon with unread badge -->
                        <Grid>
                            <Button Name="BtnNotificationCenter" ToolTip.Tip="Notification History" Cursor="Hand"
                                    Background="{DynamicResource AppCard}" BorderThickness="0" CornerRadius="20" Padding="10,6">
                                <TextBlock Text="🔔" FontSize="13" VerticalAlignment="Center"/>
                            </Button>
                            <Border Name="BellBadge" Background="#F38BA8" CornerRadius="6" Padding="3,1" HorizontalAlignment="Right" VerticalAlignment="Top" IsVisible="False" Margin="0,0,2,0">
                                <TextBlock Name="BellCount" Text="0" FontSize="8" FontWeight="Bold" Foreground="White"/>
                            </Border>
                        </Grid>
                        <Button Name="BtnThemeToggle" ToolTip.Tip="Toggle Light/Dark Mode" Cursor="Hand"
                                Background="{DynamicResource AppCard}" BorderThickness="0" CornerRadius="20" Padding="10,6">
                            <TextBlock Name="TxtThemeIcon" Text="☀" FontSize="15" VerticalAlignment="Center"/>
                        </Button>
                        <Border Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="22" Padding="14,6">
                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                <Button Name="BtnSystemInfo" Classes="Ghost" VerticalAlignment="Center" Cursor="Hand">
                                    <PathIcon Data="M11,9H13V7H11M12,20C7.59,20 4,16.41 4,12C4,7.59 7.59,4 12,4C16.41,4 20,7.59 20,12C20,16.41 16.41,20 12,20M12,2A10,10 0 0,0 2,12A10,10 0 0,0 12,22A10,10 0 0,0 22,12A10,10 0 0,0 12,2M11,17H13V11H11V17Z"
                                              Width="10" Height="10" Foreground="#A6ADC8"/>
                                </Button>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="VERSION" Foreground="#A6ADC8" FontSize="8" FontWeight="Bold" HorizontalAlignment="Right"/>
                                    <TextBlock Name="TxtVersionBadge" Text="v..." FontSize="11" FontWeight="Heavy" Foreground="{DynamicResource AppText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Notification Center Flyout -->
            <Border Name="NotificationCenter" Grid.Row="0" Grid.RowSpan="3" IsVisible="False"
                    ZIndex="998" HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,58,16,0" Width="340"
                    Background="{DynamicResource AppCard}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="12"
                    MaxHeight="420">
                <Grid RowDefinitions="Auto, *">
                    <Grid Grid.Row="0" ColumnDefinitions="*, Auto" Margin="16,14,16,10">
                        <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppSubtext}" LetterSpacing="0.5" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Name="BtnClearNotifications" Content="Clear all" Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppMuted}" BorderThickness="0" CornerRadius="6" Padding="8,4" FontSize="10" Cursor="Hand"/>
                    </Grid>
                    <ScrollViewer Grid.Row="1" MaxHeight="360" Margin="0,0,0,8">
                        <StackPanel Name="NotificationList" Spacing="2" Margin="8,0,8,8"/>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- Content Container -->
            <ContentControl Grid.Row="1" Name="MainContent" Margin="20"/>

            <Border Grid.Row="2" Name="ToastBorder" IsVisible="False" Opacity="1" HorizontalAlignment="Right" Margin="0,0,20,10"
                    Background="{DynamicResource AppSurface}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="1" CornerRadius="10" Padding="14" Width="360" IsHitTestVisible="False">
                <StackPanel Spacing="6">
                    <TextBlock Name="ToastTitle" Text="Notification" FontWeight="Bold" Foreground="#CBA6F7"/>
                    <TextBlock Name="ToastMessage" Text="" Foreground="{DynamicResource AppSubtext}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>

            <!-- Bottom Status Bar -->
            <Border Grid.Row="3" Name="StatusBar" Height="40" Background="{DynamicResource AppSidebar}" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,1,0,0" CornerRadius="0,0,12,0">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0" Spacing="10">
                        <PathIcon Name="StatusIcon" Data="{StaticResource CloudIcon}" Width="14" Height="14" Foreground="{DynamicResource AppSubtext}"/>
                        <TextBlock Name="TxtStatus" Text="SYSTEM READY" VerticalAlignment="Center" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource AppSubtext}"/>
                    </StackPanel>
                    
                    <Border Grid.Column="1" Name="HealthBadge" Background="{DynamicResource AppCard}" CornerRadius="20" Margin="10,5,20,5" Padding="12,0">
                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                            <Ellipse Name="HealthIndicator" Width="8" Height="8" Fill="#A6ADC8"/>
                            <TextBlock Name="TxtHealth" Text="HEALTH: SCANNING..." VerticalAlignment="Center" FontSize="10" FontWeight="Heavy" Foreground="{DynamicResource AppSubtext}"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <Border Name="StartupOverlay" Grid.RowSpan="4" IsVisible="False" Background="#CC000000" Padding="0" ZIndex="999">
                <Grid>
                    <Border BorderBrush="#CBA6F7" BorderThickness="1" CornerRadius="16"
                            Width="400" HorizontalAlignment="Center" VerticalAlignment="Center"
                            ClipToBounds="True" Background="{DynamicResource AppCard}">
                        <StackPanel>
                            <!-- Branded header -->
                            <Border Background="#2D2346" Padding="24,18" CornerRadius="15,15,0,0">
                                <StackPanel Orientation="Horizontal" Spacing="14" HorizontalAlignment="Center">
                                    <Image Source="/Assets/logo.ico" Width="36" Height="36" VerticalAlignment="Center"/>
                                    <StackPanel VerticalAlignment="Center" Spacing="3">
                                        <TextBlock Text="PinayPal Backup Manager" FontSize="13" FontWeight="Bold" Foreground="#CBA6F7"/>
                                        <TextBlock Text="Initializing services..." FontSize="11" Foreground="#A6ADC8"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Content -->
                            <StackPanel Spacing="14" Margin="28,22,28,26">
                                <StackPanel Spacing="6" HorizontalAlignment="Center">
                                    <TextBlock Text="Running health scan" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource AppText}" HorizontalAlignment="Center"/>
                                    <TextBlock Text="Checking all services before starting..." FontSize="11" Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center"/>
                                </StackPanel>
                                <ProgressBar IsIndeterminate="True" Height="6" CornerRadius="3" Background="{DynamicResource AppBorder}" Foreground="#CBA6F7"/>
                                <TextBlock Name="TxtStartupHint" Text="Please wait" FontSize="11" Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>

    <Window.Styles>
        <!-- Sidebar Button Animations -->
        <Style Selector="Button.SideBtn">
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="48"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.18" Easing="SineEaseOut"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.15" Easing="CubicEaseOut"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SideBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppCard}"/>
            <Setter Property="RenderTransform" Value="scale(1.06)"/>
        </Style>
        <Style Selector="Button.SideBtn.Selected">
            <Setter Property="Background" Value="#2D2346"/>
        </Style>
        <Style Selector="Button.SideBtn:pressed">
            <Setter Property="Background" Value="{DynamicResource AppCard}"/>
            <Setter Property="RenderTransform" Value="scale(0.93)"/>
        </Style>

        <!-- Sidebar Button Icons -->
        <Style Selector="Button.SideBtn PathIcon">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.18"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SideBtn:pointerover PathIcon">
            <Setter Property="Foreground" Value="#CBA6F7"/>
        </Style>
        <Style Selector="Button.SideBtn.Selected PathIcon">
            <Setter Property="Foreground" Value="#CBA6F7"/>
        </Style>

        <!-- Profile Menu Styles -->
        <Style Selector="Button.ProfileMenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="8,4"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="FontSize" Value="9"/>
            <Setter Property="Foreground" Value="#A6ADC8"/>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border Background="{TemplateBinding Background}" 
                            Padding="{TemplateBinding Padding}"
                            CornerRadius="4">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <ContentPresenter Content="{TemplateBinding Tag}" Margin="0,0,4,0"/>
                            <ContentPresenter Content="{TemplateBinding Content}"/>
                        </StackPanel>
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.ProfileMenuItem:pointerover">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
        </Style>
        <Style Selector="Button.ProfileMenuItem:pressed">
            <Setter Property="Background" Value="#45475A"/>
        </Style>
        <Style Selector="Button.LogoutBtn">
            <Setter Property="Foreground" Value="#F38BA8"/>
        </Style>
        <Style Selector="Button.LogoutBtn:pointerover">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#1E1E2E"/>
        </Style>

        <!-- Content Control Fade-in Animation -->
        <Style Selector="ContentControl">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.4"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Toast Notification Animations -->
        <Style Selector="Border#ToastBorder">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.3"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border#ToastBorder:hidden">
            <Setter Property="RenderTransform" Value="translateX(400px)"/>
        </Style>

        <!-- Border Hover Effects -->
        <Style Selector="Border">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Status Bar Animation -->
        <Style Selector="Border#StatusBar">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.3"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Health Indicator Pulse Animation -->
        <Style Selector="Ellipse#HealthIndicator">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Fill" Duration="0:0:0.5"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.5"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Profile Control Button Styles -->
        <Style Selector="Button.PrimaryBtn">
            <Setter Property="Background" Value="#89B4FA"/>
            <Setter Property="Foreground" Value="#0B0F17"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.PrimaryBtn:pointerover">
            <Setter Property="Background" Value="#74A6F0"/>
        </Style>
        <Style Selector="Button.PrimaryBtn:pressed">
            <Setter Property="Background" Value="#5E8FD8"/>
        </Style>

        <Style Selector="Button.SecondaryBtn">
            <Setter Property="Background" Value="#313244"/>
            <Setter Property="Foreground" Value="#CDD6F4"/>
            <Setter Property="BorderBrush" Value="#45475A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SecondaryBtn:pointerover">
            <Setter Property="Background" Value="#45475A"/>
            <Setter Property="BorderBrush" Value="#585B70"/>
        </Style>
        <Style Selector="Button.SecondaryBtn:pressed">
            <Setter Property="Background" Value="#585B70"/>
        </Style>

        <Style Selector="Button.DangerBtn">
            <Setter Property="Background" Value="#F38BA8"/>
            <Setter Property="Foreground" Value="#0B0F17"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.25"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.DangerBtn:pointerover">
            <Setter Property="Background" Value="#E5748E"/>
        </Style>
        <Style Selector="Button.DangerBtn:pressed">
            <Setter Property="Background" Value="#D95A76"/>
        </Style>
    </Window.Styles>

    <Window.Resources>
        <StreamGeometry x:Key="HomeIcon">M10,20V14H14V20H19V12H22L12,3L2,12H5V20H10Z</StreamGeometry>
        <StreamGeometry x:Key="CloudIcon">M6,20C3.24,20 1,17.76 1,15C1,12.56 2.78,10.53 5.12,10.12C6.04,7.18 8.77,5 12,5C15.4,5 18.25,7.44 18.88,10.68C21.22,10.9 23,12.85 23,15.25C23,17.87 20.87,20 18.25,20H6M12,7C9.5,7 7.4,8.5 6.4,10.7L6.1,11.3L5.4,11.3C3.9,11.5 2.8,12.7 2.8,14.2C2.8,15.8 4.1,17.2 5.7,17.2H17.2C18.8,17.2 20.2,15.8 20.2,14.2C20.2,12.6 18.8,11.2 17.2,11.2H16.2L16,10.2C15.5,8.1 13.7,6.6 11.5,6.6L12,7Z</StreamGeometry>
        <StreamGeometry x:Key="MailIcon">M20,4H4C2.9,4 2,4.9 2,6V18C2,19.1 2.9,20 4,20H20C21.1,20 22,19.1 22,18V6C22,4.9 21.1,4 20,4M20,18H4V8L12,13L20,8V18M12,11L4,6H20L12,11Z</StreamGeometry>
        <StreamGeometry x:Key="DatabaseIcon">M12,3C7.58,3 4,4.79 4,7C4,9.21 7.58,11 12,11C16.42,11 20,9.21 20,7C20,4.79 16.42,3 12,3M4,9V12C4,14.21 7.58,16 12,16C16.42,16 20,14.21 20,12V9C20,11.21 16.42,13 12,13C7.58,13 4,11.21 4,9M4,14V17C4,19.21 7.58,21 12,21C16.42,21 20,19.21 20,17V14C20,16.21 16.42,18 12,18C7.58,18 4,16.21 4,14Z</StreamGeometry>
        <StreamGeometry x:Key="SettingsIcon">M12,15.5A3.5,3.5 0 0,1 8.5,12A3.5,3.5 0 0,1 12,8.5A3.5,3.5 0 0,1 15.5,12A3.5,3.5 0 0,1 12,15.5M19.43,12.97C19.47,12.65 19.5,12.33 19.5,12C19.5,11.67 19.47,11.34 19.43,11.03L21.54,9.37C21.73,9.22 21.78,8.95 21.66,8.73L19.66,5.27C19.54,5.05 19.27,4.96 19.05,5.05L16.56,6.05C16.04,5.66 15.5,5.32 14.87,5.07L14.5,2.42C14.46,2.18 14.25,2 14,2H10C9.75,2 9.54,2.18 9.5,2.42L9.13,5.07C8.5,5.32 7.96,5.66 7.44,6.05L4.95,5.05C4.73,4.96 4.46,5.05 4.34,5.27L2.34,8.73C2.22,8.95 2.27,9.22 2.46,9.37L4.57,11.03C4.53,11.34 4.5,11.67 4.5,12C4.5,12.33 4.53,12.65 4.57,12.97L2.46,14.63C2.27,14.78 2.22,15.05 2.34,15.27L4.34,18.73C4.46,18.95 4.73,19.04 4.95,18.95L7.44,17.95C7.96,18.34 8.5,18.68 9.13,18.93L9.5,21.58C9.54,21.82 9.75,22 10,22H14C14.25,22 14.46,21.82 14.5,21.58L14.87,18.93C15.5,18.68 16.04,18.34 16.56,17.95L19.05,18.95C19.27,19.04 19.54,18.95 19.66,18.73L21.66,15.27C21.78,15.05 21.73,14.78 21.54,14.63L19.43,12.97Z</StreamGeometry>
    </Window.Resources>
</Window>
