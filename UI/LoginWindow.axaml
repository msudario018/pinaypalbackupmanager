<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="PinayPalBackupManager.UI.LoginWindow"
        Title="PinayPal Backup Manager — Login"
        Width="440" Height="580"
        WindowStartupLocation="CenterScreen"
        CanResize="False"
        Background="{DynamicResource AppBg}"
        Foreground="{DynamicResource AppText}"
        Icon="/Assets/logo.ico">

    <Grid RowDefinitions="Auto, *">
        <!-- Header -->
        <Border Grid.Row="0" Background="{DynamicResource AppTopBar}" Padding="20,18" BorderBrush="{DynamicResource AppBorder}" BorderThickness="0,0,0,1">
            <StackPanel HorizontalAlignment="Center" Spacing="6">
                <TextBlock Text="PinayPal Backup Manager" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource AccentWebsite}" HorizontalAlignment="Center"/>
                <TextBlock Name="TxtSubtitle" Text="Sign in to continue" FontSize="12" Foreground="{DynamicResource AppMuted}" HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Login Panel -->
        <Border Grid.Row="1" Name="LoginPanel" IsVisible="True" Margin="24,16" Background="{DynamicResource AppCard}" CornerRadius="14" Padding="24">
            <StackPanel Spacing="10" VerticalAlignment="Center">
                <TextBlock Text="LOGIN" FontWeight="Bold" Foreground="{DynamicResource AccentFtp}" FontSize="13" Margin="0,0,0,4"/>

                <TextBlock Text="Username" Foreground="{DynamicResource AppMuted}" FontSize="11" FontWeight="Bold"/>
                <TextBox Name="TxtLoginUser" Watermark="Enter username"/>

                <TextBlock Text="Password" Foreground="{DynamicResource AppMuted}" FontSize="11" FontWeight="Bold"/>
                <TextBox Name="TxtLoginPass" Watermark="Enter password" PasswordChar="●"/>

                <TextBlock Name="TxtLoginError" Text="" Foreground="{DynamicResource AccentError}" FontSize="11" TextWrapping="Wrap"/>

                <Button Name="BtnLogin" Content="SIGN IN" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{DynamicResource AccentWebsite}" Foreground="#000000" FontWeight="Bold" Padding="10" CornerRadius="8"/>

                <CheckBox Name="ChkRememberMe" Content="Stay logged in" Classes="Modern"
                          Foreground="{DynamicResource AppMuted}" FontSize="11"
                          HorizontalAlignment="Center"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,2,0,0">
                    <TextBlock Text="Don't have an account?" Foreground="{DynamicResource AppMuted}" FontSize="11"/>
                    <Button Name="BtnShowRegister" Content="Register" Classes="Link" Foreground="{DynamicResource AccentWebsite}" FontSize="11" 
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- 2FA Panel -->
        <Border Grid.Row="1" Name="TwoFactorPanel" IsVisible="False" Margin="24,16" Background="{DynamicResource AppCard}" CornerRadius="14" Padding="24">
            <StackPanel Spacing="12" VerticalAlignment="Center">
                <TextBlock Text="TWO-FACTOR AUTHENTICATION" FontWeight="Bold" Foreground="{DynamicResource AccentFtp}" FontSize="13" Margin="0,0,0,4"/>
                <TextBlock Text="Enter the 6-digit code from your authenticator app" Foreground="{DynamicResource AppMuted}" FontSize="11" TextWrapping="Wrap"/>

                <TextBox Name="Txt2FACode" Watermark="6-digit code or recovery code" FontSize="14" Padding="12,10"/>

                <CheckBox Name="ChkRememberDevice" Content="Remember this device for 30 days" Classes="Modern"
                          Foreground="{DynamicResource AppMuted}" FontSize="11"
                          HorizontalAlignment="Center"/>

                <TextBlock Name="Txt2FAError" Text="" Foreground="{DynamicResource AccentError}" FontSize="10" TextWrapping="Wrap"/>
                <TextBlock Text="Lost your phone? Enter a recovery code instead" Foreground="{DynamicResource AppMuted}" FontSize="10" TextWrapping="Wrap"/>

                <Button Name="BtnVerify2FA" Content="VERIFY CODE" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{DynamicResource AccentFtp}" Foreground="#000000" FontWeight="Bold" Padding="10" CornerRadius="8"/>

                <Button Name="BtnBackToLogin" Content="BACK" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{DynamicResource AppBorder}" Foreground="{DynamicResource AppText}" FontWeight="Bold" Padding="10" CornerRadius="8"/>
            </StackPanel>
        </Border>

        <!-- Register Panel -->
        <Border Grid.Row="1" Name="RegisterPanel" IsVisible="False" Margin="30,20" Background="{DynamicResource AppCard}" CornerRadius="14" Padding="28">
            <StackPanel Spacing="14" VerticalAlignment="Center">
                <TextBlock Name="TxtRegTitle" Text="CREATE ACCOUNT" FontWeight="Bold" Foreground="{DynamicResource AccentWebsite}" FontSize="13" Margin="0,0,0,4"/>

                <TextBlock Text="Username" Foreground="{DynamicResource AppMuted}" FontSize="11" FontWeight="Bold"/>
                <TextBox Name="TxtRegUser" Watermark="Choose a username"/>

                <TextBlock Text="Password" Foreground="{DynamicResource AppMuted}" FontSize="11" FontWeight="Bold"/>
                <TextBox Name="TxtRegPass" Watermark="Choose a password" PasswordChar="●"/>

                <StackPanel Name="InviteCodePanel" Spacing="4">
                    <TextBlock Text="Invite Code" Foreground="{DynamicResource AppMuted}" FontSize="11" FontWeight="Bold"/>
                    <TextBox Name="TxtInviteCode" Watermark="Enter invite code from admin"/>
                </StackPanel>

                <TextBlock Name="TxtRegError" Text="" Foreground="{DynamicResource AccentError}" FontSize="11" TextWrapping="Wrap"/>

                <Button Name="BtnRegister" Content="REGISTER" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                        Background="{DynamicResource AccentWebsite}" Foreground="#000000" FontWeight="Bold" Padding="12" CornerRadius="8" Margin="0,6,0,0"/>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4" Margin="0,8,0,0">
                    <TextBlock Text="Already have an account?" Foreground="{DynamicResource AppMuted}" FontSize="11"/>
                    <Button Name="BtnShowLogin" Content="Sign in" Classes="Link" Foreground="{DynamicResource AccentFtp}" FontSize="11" 
                            Background="Transparent" BorderThickness="0" Padding="0" Cursor="Hand"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>

    <Window.Styles>
        <Style Selector="TextBox">
            <Setter Property="Background" Value="{DynamicResource AppSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="TextBox:focus">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentWebsite}"/>
        </Style>
        <Style Selector="Button.Link:pointerover">
            <Setter Property="Foreground" Value="{DynamicResource AccentWebsite}"/>
        </Style>

        <!-- Modern CheckBox Style -->
        <Style Selector="CheckBox.Modern">
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Padding" Value="8,0,0,0"/>
        </Style>
        <Style Selector="CheckBox.Modern /template/ Border#NormalRectangle">
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Background" Value="{DynamicResource AppSurface}"/>
            <Setter Property="Width" Value="18"/>
            <Setter Property="Height" Value="18"/>
        </Style>
        <Style Selector="CheckBox.Modern:checked /template/ Border#NormalRectangle">
            <Setter Property="Background" Value="{DynamicResource AccentWebsite}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentWebsite}"/>
        </Style>
        <Style Selector="CheckBox.Modern:pointerover /template/ Border#NormalRectangle">
            <Setter Property="BorderBrush" Value="{DynamicResource AccentWebsite}"/>
        </Style>
        <Style Selector="CheckBox.Modern /template/ Path#CheckMark">
            <Setter Property="Stroke" Value="{DynamicResource AppTopBar}"/>
            <Setter Property="StrokeThickness" Value="2"/>
        </Style>
        <Style Selector="CheckBox.Modern:checked > ContentPresenter">
            <Setter Property="TextBlock.Foreground" Value="{DynamicResource AppText}"/>
        </Style>
    </Window.Styles>
</Window>
