<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="PinayPalBackupManager.App"
             RequestedThemeVariant="Dark">
    <Application.Styles>
        <FluentTheme />

        <!-- GLOBAL ANIMATIONS & TRANSITIONS -->
        <!-- Global Button Animations - Optimized for faster theme switching -->
        <Style Selector="Button">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Sidebar Button Animations - Optimized -->
        <Style Selector="Button.SideBtn">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.SideBtn:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.08) translateY(-1px)"/>
        </Style>
        <Style Selector="Button.SideBtn:pressed">
            <Setter Property="RenderTransform" Value="scale(0.95)"/>
        </Style>
        <Style Selector="Button.SideBtn.Selected">
            <Setter Property="RenderTransform" Value="scale(1.0)"/>
        </Style>

        <!-- Border Animations - Optimized for faster theme switching -->
        <Style Selector="Border">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- TextBlock Animations - Optimized -->
        <Style Selector="TextBlock">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Foreground" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ListBox Item Animations - Optimized -->
        <Style Selector="ListBoxItem">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- DataGridRow Animations - Optimized -->
        <Style Selector="DataGridRow">
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.08"/>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Content Control Fade-in - Optimized -->
        <Style Selector="ContentControl">
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Opacity" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- Modern Glassmorphism Card Style -->
        <Style Selector="Border.glass">
            <Setter Property="Background" Value="{DynamicResource AppGlass}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="16"/>
            <Setter Property="BoxShadow" Value="0 4 16 #00000020, 0 8 32 #00000010"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Border.glass:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppGlassHover}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>

        <!-- Enhanced Modern Button Styles -->
        <Style Selector="Button.modern">
            <Setter Property="Background" Value="{DynamicResource AppSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.modern:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="RenderTransform" Value="scale(1.05) translateY(-2px)"/>
        </Style>
        <Style Selector="Button.modern:pressed">
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <!-- Floating Action Button Style -->
        <Style Selector="Button.fab">
            <Setter Property="Background" Value="{DynamicResource AccentWebsite}"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CornerRadius" Value="50"/>
            <Setter Property="Width" Value="56"/>
            <Setter Property="Height" Value="56"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Transitions">
                <Transitions>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.1"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.fab:pointerover">
            <Setter Property="RenderTransform" Value="scale(1.1) translateY(-4px)"/>
            <Setter Property="Background" Value="{DynamicResource AccentWebsiteLight}"/>
        </Style>

        <!-- ProgressBar smooth value transition and style - Optimized -->
        <Style Selector="ProgressBar">
            <Setter Property="Height" Value="10"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Transitions">
                <Transitions>
                    <DoubleTransition Property="Value" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>

        <Style Selector="Button.Primary">
            <Setter Property="Background" Value="{DynamicResource AccentWebsite}"/>
            <Setter Property="Foreground" Value="#000000"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="18,10"/>
        </Style>

        <Style Selector="Button.Primary.Ftp">
            <Setter Property="Background" Value="{DynamicResource AccentFtp}"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Button.Primary.Mailchimp">
            <Setter Property="Background" Value="{DynamicResource AccentMailchimp}"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Button.Primary.Sql">
            <Setter Property="Background" Value="{DynamicResource AccentSql}"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Button.Primary.Settings">
            <Setter Property="Background" Value="{DynamicResource AccentWebsite}"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Button.Primary.Website">
            <Setter Property="Background" Value="{DynamicResource AccentWebsite}"/>
            <Setter Property="Foreground" Value="#000000"/>
        </Style>
        <Style Selector="Button.Primary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AccentWebsiteLight}"/>
            <Setter Property="RenderTransform" Value="scale(1.03)"/>
        </Style>
        <Style Selector="Button.Primary:pressed">
            <Setter Property="Background" Value="{DynamicResource AccentWebsiteDark}"/>
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <Style Selector="Button.Secondary">
            <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,9"/>
        </Style>
        <Style Selector="Button.Secondary:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppMuted}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.Secondary:pressed">
            <Setter Property="Background" Value="{DynamicResource AppSubtext}"/>
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <Style Selector="Button.Danger">
            <Setter Property="Background" Value="#0B0F17"/>
            <Setter Property="Foreground" Value="#F38BA8"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,9"/>
        </Style>
        <Style Selector="Button.Danger:pointerover">
            <Setter Property="Background" Value="#FFB3C7"/>
            <Setter Property="Foreground" Value="#0B0F17"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.Danger:pressed">
            <Setter Property="Background" Value="#E37A92"/>
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

        <!-- Admin Button Style - Uses muted color palette -->
        <Style Selector="Button.Admin">
            <Setter Property="Background" Value="{DynamicResource AppSurface}"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorder}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.1"/>
                    <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.08"/>
                </Transitions>
            </Setter>
        </Style>
        <Style Selector="Button.Admin:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppCard}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource AccentFtp}"/>
            <Setter Property="RenderTransform" Value="scale(1.03)"/>
        </Style>
        <Style Selector="Button.Admin:pressed">
            <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
            <Setter Property="RenderTransform" Value="scale(0.98)"/>
        </Style>

        <Style Selector="Button.Ghost">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="{DynamicResource AppText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="10,8"/>
        </Style>
        <Style Selector="Button.Ghost:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppCard}"/>
            <Setter Property="RenderTransform" Value="scale(1.02)"/>
        </Style>
        <Style Selector="Button.Ghost:pressed">
            <Setter Property="Background" Value="{DynamicResource AppBorder}"/>
            <Setter Property="RenderTransform" Value="scale(0.97)"/>
        </Style>

    </Application.Styles>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.ThemeDictionaries>
                <ResourceDictionary x:Key="Dark">
                    <!-- Tea-Green Color Palette - Dark Theme -->
                    <SolidColorBrush x:Key="AppBg">#1A1F1A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSidebar">#2D342D</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTopBar">#2D342D</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCard">#3D453D</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSurface">#4A524A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppText">#FEFAE0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSubtext">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="AppMuted">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="AppVeryMuted">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorder">#5A625A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorder2">#4A524A</SolidColorBrush>
                    
                    <!-- Enhanced Transparency Layers -->
                    <SolidColorBrush x:Key="AppGlass">#FFFFFF0A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppGlassHover">#FFFFFF15</SolidColorBrush>
                    <SolidColorBrush x:Key="AppShadow">#00000040</SolidColorBrush>
                    <SolidColorBrush x:Key="AppOverlay">#0A0A0F80</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTimerAutoScan">#2D1A0E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTimerDaily">#1A1040</SolidColorBrush>
                    <SolidColorBrush x:Key="AppManilaTime">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="AppLogText">#FEFAE0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppWarning">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnGreen">#112B1E</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnBlue">#0D1A22</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnRed">#2D1515</SolidColorBrush>

                    <!-- Backup Tab Specific Colors -->
                    <!-- FTP/Website - Green Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentFtp">#6b8e6b</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpLight">#a8c6a8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpDark">#4a6b50</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpBg">#3d5a4e</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpMuted">#c9d4c5</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpSurface">#6b8e6b</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpGlow">#6b8e6b40</SolidColorBrush>

                    <!-- Mailchimp - Blue Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentMailchimp">#48a9c9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpLight">#b8e0e8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpDark">#3a7ca5</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpBg">#1a3a5a</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpMuted">#7ac8d8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpSurface">#48a9c9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpGlow">#48a9c940</SolidColorBrush>

                    <!-- SQL - Gold Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentSql">#e6c55c</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlLight">#f0d878</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlDark">#b8963a</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlBg">#8a6b30</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlMuted">#d4b84d</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlSurface">#e6c55c</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlGlow">#e6c55c40</SolidColorBrush>

                    <!-- Website/General - Tea-Green Purple -->
                    <SolidColorBrush x:Key="AccentWebsite">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteLight">#E9EDC9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteDark">#B5C99A</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteBg">#4A524A</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteMuted">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteSurface">#5A625A</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteGlow">#CCD5AE40</SolidColorBrush>

                    <!-- Error - Tea-Green Red -->
                    <SolidColorBrush x:Key="AccentError">#F38BA8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorLight">#FFB3C7</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorDark">#E37A92</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorBg">#2D1515</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorMuted">#FFD1DC</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorSurface">#9D1D35</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorGlow">#F38BA840</SolidColorBrush>

                    <!-- Tea-Green Sidebar Theme -->
                    <SolidColorBrush x:Key="SidebarIconMuted">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarIconActive">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarSelectedBg">#4A524A</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarDivider">#5A625A</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarGlow">#CCD5AE20</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarHover">#FFFFFF10</SolidColorBrush>
                </ResourceDictionary>
                <ResourceDictionary x:Key="Light">
                    <!-- Tea-Green Color Palette - Light Theme -->
                    <SolidColorBrush x:Key="AppBg">#FEFAE0</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSidebar">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTopBar">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="AppCard">#E9EDC9</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSurface">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="AppText">#1A1F1A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppSubtext">#2D342D</SolidColorBrush>
                    <SolidColorBrush x:Key="AppMuted">#4A524A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppVeryMuted">#5A625A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorder">#B5C99A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBorder2">#CCD5AE</SolidColorBrush>
                    
                    <!-- Enhanced Transparency Layers for Light Theme -->
                    <SolidColorBrush x:Key="AppGlass">#00000005</SolidColorBrush>
                    <SolidColorBrush x:Key="AppGlassHover">#00000010</SolidColorBrush>
                    <SolidColorBrush x:Key="AppShadow">#00000020</SolidColorBrush>
                    <SolidColorBrush x:Key="AppOverlay">#F8FAFC80</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTimerAutoScan">#FFF8E1</SolidColorBrush>
                    <SolidColorBrush x:Key="AppTimerDaily">#F8F8F8</SolidColorBrush>
                    <SolidColorBrush x:Key="AppManilaTime">#B5C99A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppLogText">#1A1F1A</SolidColorBrush>
                    <SolidColorBrush x:Key="AppWarning">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnGreen">#D8F3DC</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnBlue">#CAF0F8</SolidColorBrush>
                    <SolidColorBrush x:Key="AppBtnRed">#FEE2E2</SolidColorBrush>

                    <!-- Backup Tab Specific Colors (Light) -->
                    <!-- FTP/Website - Green Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentFtp">#6b8e6b</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpLight">#a8c6a8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpDark">#4a6b50</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpBg">#c9d4c5</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpMuted">#a8c6a8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpSurface">#6b8e6b</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentFtpGlow">#6b8e6b30</SolidColorBrush>

                    <!-- Mailchimp - Blue Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentMailchimp">#48a9c9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpLight">#b8e0e8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpDark">#3a7ca5</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpBg">#b8e0e8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpMuted">#7ac8d8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpSurface">#48a9c9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentMailchimpGlow">#48a9c930</SolidColorBrush>

                    <!-- SQL - Gold Theme (Modernized) -->
                    <SolidColorBrush x:Key="AccentSql">#e6c55c</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlLight">#f0d878</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlDark">#b8963a</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlBg">#f0d878</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlMuted">#d4b84d</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlSurface">#e6c55c</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentSqlGlow">#e6c55c30</SolidColorBrush>

                    <!-- Website/General - Tea-Green Purple -->
                    <SolidColorBrush x:Key="AccentWebsite">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteLight">#E9EDC9</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteDark">#B5C99A</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteBg">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteMuted">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteSurface">#4A524A</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentWebsiteGlow">#CCD5AE20</SolidColorBrush>

                    <!-- Error - Tea-Green Red -->
                    <SolidColorBrush x:Key="AccentError">#F38BA8</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorLight">#FFB3C7</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorDark">#E37A92</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorBg">#FEE2E2</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorMuted">#FFD1DC</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorSurface">#9D1D35</SolidColorBrush>
                    <SolidColorBrush x:Key="AccentErrorGlow">#F38BA820</SolidColorBrush>

                    <!-- Tea-Green Sidebar Theme (Light) -->
                    <SolidColorBrush x:Key="SidebarIconMuted">#CCD5AE</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarIconActive">#D4A373</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarSelectedBg">#FAEDCD</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarDivider">#B5C99A</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarGlow">#CCD5AE15</SolidColorBrush>
                    <SolidColorBrush x:Key="SidebarHover">#00000005</SolidColorBrush>
                </ResourceDictionary>
            </ResourceDictionary.ThemeDictionaries>
            <Color x:Key="ColorBg">#000000</Color>
            <Color x:Key="ColorSurface">#14213D</Color>
            <Color x:Key="ColorSurface2">#1A1F36</Color>
            <Color x:Key="ColorBorder">#2D3748</Color>
            <Color x:Key="ColorText">#FFFFFF</Color>
            <Color x:Key="ColorMuted">#E5E5E5</Color>
            <Color x:Key="ColorAccentFtp">#6b8e6b</Color>
            <Color x:Key="ColorAccentMailchimp">#48a9c9</Color>
            <Color x:Key="ColorAccentSql">#e6c55c</Color>
            <Color x:Key="ColorAccentWebsite">#A78BFA</Color>
        </ResourceDictionary>
    </Application.Resources>
</Application>
